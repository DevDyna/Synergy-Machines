{
  "multipart": [
    {
      "apply": {
        "model": "machines:block/solar_panel/night/core_cell"
      }
    },

    {
      "when": {
        "north": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side"
      }
    },
    {
      "when": {
        "east": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side",
        "y": 90
      }
    },
    {
      "when": {
        "south": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side",
        "y": 180
      }
    },
    {
      "when": {
        "west": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side",
        "y": 270
      }
    },

    {
      "when": {
        "north": "true",
        "east": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half_alt"
      }
    },
    {
      "when": {
        "east": "true",
        "north": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true",
        "east": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half",
        "y": 180
      }
    },
    {
      "when": {
        "west": "true",
        "north": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half_alt",
        "y": 270
      }
    },

    {
      "when": {
        "north": "true",
        "west": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half"
      }
    },
    {
      "when": {
        "east": "true",
        "south": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half_alt",
        "y": 90
      }
    },
    {
      "when": {
        "south": "true",
        "west": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half_alt",
        "y": 180
      }
    },
    {
      "when": {
        "west": "true",
        "south": "false"
      },
      "apply": {
        "model": "machines:block/solar_panel/side_half",
        "y": 270
      }
    },

    {
      "when": {
        "north": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/cell/north"
      }
    },
    {
      "when": {
        "east": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/cell/east"
      }
    },
    {
      "when": {
        "south": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/cell/south"
      }
    },
    {
      "when": {
        "west": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/cell/west"
      }
    },
    {
      "when": {
        "north": "true",
        "east": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/angle/north_east"
      }
    },
    {
      "when": {
        "north": "true",
        "west": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/angle/north_west"
      }
    },
    {
      "when": {
        "south": "true",
        "east": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/angle/south_east"
      }
    },
    {
      "when": {
        "south": "true",
        "west": "true"
      },
      "apply": {
        "model": "machines:block/solar_panel/night/angle/south_west"
      }
    }
  ]
}
